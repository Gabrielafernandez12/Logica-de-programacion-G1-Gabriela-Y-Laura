# Función para validar que el input sea un número positivo
def validar_numero(valor):
    try:
        numero = int(valor)
        if numero <= 0:
            print("❌ Por favor, ingrese un número positivo.")
            return None
        return numero
    except ValueError:
        print("❌ Entrada no válida. Por favor, ingrese un número entero.")
        return None


# Función para calcular propiedades del número
def calcular_propiedades(numero):
    """
    Calcula la raíz cuadrada, cuadrado y cubo de un número.
    """
    raiz = numero ** 0.5
    cuadrado = numero ** 2
    cubo = numero ** 3
    return raiz, cuadrado, cubo


# Función para mostrar resultados
def mostrar_resultados(numero, raiz, cuadrado, cubo):
    """
    Muestra los resultados de forma formateada.
    """
    print(f"\n📊 Resultados para el número: {numero}")
    print(f"   Raíz cuadrada:  {raiz:.2f}")
    print(f"   Cuadrado:       {cuadrado}")
    print(f"   Cubo:           {cubo}")
    print("   " + "-" * 40)


# Función principal
def main():
    try:
        # Solicitar la cantidad de números
        while True:
            try:
                n = int(input("\n¿Cuántos números desea procesar? "))
                if n <= 0:
                    print("❌ Ingrese un número mayor a 0.")
                    continue
                if n > 100:
                    print("⚠️  Se limitará a 100 números.")
                    n = 100
                break
            except ValueError:
                print("❌ Entrada no válida. Por favor, ingrese un número entero.")
        
        # Procesar cada número
        for i in range(1, n + 1):
            print(f"\n--- Número {i} de {n} ---")
            
            while True:
                numero_input = input("Ingrese un número entero positivo: ")
                numero = validar_numero(numero_input)
                
                if numero is not None:
                    raiz, cuadrado, cubo = calcular_propiedades(numero)
                    mostrar_resultados(numero, raiz, cuadrado, cubo)
                    break
        
        print("\n✅ ¡Proceso completado exitosamente!")
    
    except KeyboardInterrupt:
        print("\n\n⚠️  Programa interrumpido por el usuario.")
    except Exception as e:
        print(f"\n❌ Se produjo un error inesperado: {e}")


# Ejecutar el programa
if __name__ == "__main__":
    main()