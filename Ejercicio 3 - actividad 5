import math

def calcular_potencias(numeros):
    for numero in numeros:
        raiz = math.sqrt(numero)
        cuadrado = numero ** 2
        cubo = numero ** 3

        print(f"Número: {numero}")
        print(f"  Raíz cuadrada: {raiz}")
        print(f"  Cuadrado: {cuadrado}")
        print(f"  Cubo: {cubo}")
        print("-" * 30)

def main():
    print("Ingrese números enteros positivos separados por espacio:")
    entrada = input()

    # Convertir la entrada en lista de enteros
    numeros = list(map(int, entrada.split()))

    # Validación: solo positivos
    numeros_positivos = [n for n in numeros if n > 0]

    if len(numeros_positivos) != len(numeros):
        print("Solo se tomarán en cuenta los números positivos.")

    calcular_potencias(numeros_positivos)

if __name__ == "__main__":
    main()
