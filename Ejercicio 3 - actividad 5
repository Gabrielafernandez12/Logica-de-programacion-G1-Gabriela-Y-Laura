n = int(input("Ingrese la cantidad de números: "))

for i in range(n):
    numero = int(input("Ingrese un número entero positivo: "))

    raiz = numero ** 0.5
    cuadrado = numero ** 2
    cubo = numero ** 3

    print("Número:", numero)
    print("Raíz cuadrada:", raiz)
    print("Cuadrado:", cuadrado)
    print("Cubo:", cubo)
    print("-------------------")
