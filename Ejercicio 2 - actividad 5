const datos = [2, 4, 6];

let suma = 0;
let sumaDeCuadrados = 0;

// Sumar datos
for (let i = 0; i < datos.length; i++) {
    suma += datos[i];
}

let promedio = suma / datos.length;

// Sumar cuadrados
for (let i = 0; i < datos.length; i++) {
    sumaDeCuadrados += Math.pow(datos[i] - promedio, 2);
}

let desviacion = Math.sqrt(sumaDeCuadrados / datos.length);

console.log("Desviación estándar:", desviacion);
