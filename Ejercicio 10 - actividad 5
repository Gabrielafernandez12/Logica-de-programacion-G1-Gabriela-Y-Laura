M = int(input("Ingrese M: "))
primos = []

for num in range(2, M + 1):
    es_primo = True
    for i in range(2, int(num**0.5) + 1):
        if num % i == 0:
            es_primo = False
            break
    if es_primo:
        primos.append(num)

print(f"Primos: {primos}")
print(f"Suma: {sum(primos)}")
print(f"Total: {len(primos)}")
