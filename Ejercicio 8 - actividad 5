temperaturas = []
suma = 0

for dia in range(1, 31):
    temp = float(input(f"Temp día {dia}: "))
    temperaturas.append(temp)
    suma += temp

promedio = suma / 30
maxima = max(temperaturas)
minima = min(temperaturas)

encima = len([t for t in temperaturas if t > promedio])
debajo = len([t for t in temperaturas if t < promedio])

print(f"Promedio: {promedio}, Max: {maxima}, Min: {minima}, Encima: {encima}, Debajo: {debajo}"
