
def calcular_retencion(salario: float, num_hijos: int) -> float:
    """
    Determina el porcentaje de retención según las reglas de negocio.

    Salario < 300.000:
      - Hijos > 6  → 0% de retención
      - Hijos <= 6 → retención = (6 - hijos) / 2  %

    Salario >= 300.000:
      - Hijos < 3  → 3% de retención
      - Hijos >= 3 → retención = 10 / hijos  %
    """
    if salario < 300_000:
        if num_hijos > 6:
            porcentaje = 0.0
        else:
            porcentaje = (6 - num_hijos) / 2
    else:
        if num_hijos < 3:
            porcentaje = 3.0
        else:
            porcentaje = 10 / num_hijos

    return porcentaje


